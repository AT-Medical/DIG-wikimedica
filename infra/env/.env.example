# =============================================================================
# Wikimedica — Environment Variables Example
# =============================================================================
# Copy this file to .env and fill in all values.
# NEVER commit the .env file to version control.
# The .gitignore is configured to exclude .env.
#
# Production: place .env at infra/env/.env on the VPS.
# GitHub Actions: configure these as repository Secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Domain
# -----------------------------------------------------------------------------

# Primary domain for the Wikimedica instance
DOMAIN=wikimedica.de

# -----------------------------------------------------------------------------
# MediaWiki — Database
# -----------------------------------------------------------------------------

# Database host (Docker service name in production)
MEDIAWIKI_DB_HOST=mariadb

# Database name
MEDIAWIKI_DB_NAME=wikimedica

# Database user for MediaWiki application
MEDIAWIKI_DB_USER=wikimedica_app

# Database password for MediaWiki application user (use a strong random string)
MEDIAWIKI_DB_PASSWORD=REPLACE_WITH_STRONG_RANDOM_PASSWORD

# Root database password (used for initial setup and backups)
MEDIAWIKI_DB_ROOT_PASSWORD=REPLACE_WITH_STRONG_ROOT_PASSWORD

# -----------------------------------------------------------------------------
# MediaWiki — Application
# -----------------------------------------------------------------------------

# MediaWiki secret key (generate with: openssl rand -hex 32)
MEDIAWIKI_SECRET_KEY=REPLACE_WITH_64_CHARACTER_HEX_STRING

# MediaWiki upgrade key (generate with: openssl rand -hex 8)
MEDIAWIKI_UPGRADE_KEY=REPLACE_WITH_16_CHARACTER_HEX_STRING

# Site name displayed in MediaWiki
MEDIAWIKI_SITE_NAME=Wikimedica

# Administrator username for initial setup
MEDIAWIKI_ADMIN_USER=admin

# Administrator password for initial setup (change immediately after setup)
MEDIAWIKI_ADMIN_PASS=REPLACE_WITH_SECURE_ADMIN_PASSWORD

# -----------------------------------------------------------------------------
# Traefik & TLS
# -----------------------------------------------------------------------------

# Email address for Let's Encrypt ACME registration
TRAEFIK_ACME_EMAIL=tech@wikimedica.de

# Cloudflare API token with Zone:DNS:Edit permission for your domain
# Used by Traefik for DNS-01 Let's Encrypt challenge
CLOUDFLARE_API_TOKEN=REPLACE_WITH_CLOUDFLARE_API_TOKEN

# Cloudflare Zone ID (found in Cloudflare dashboard → your domain → Overview)
CLOUDFLARE_ZONE_ID=REPLACE_WITH_CLOUDFLARE_ZONE_ID

# -----------------------------------------------------------------------------
# PubMed Surveillance
# -----------------------------------------------------------------------------

# NCBI Entrez API key (register at: https://www.ncbi.nlm.nih.gov/account/)
# Without this, rate limiting applies (3 req/s instead of 10 req/s)
NCBI_API_KEY=REPLACE_WITH_NCBI_API_KEY

# Email registered with NCBI (required by Entrez API terms of service)
NCBI_EMAIL=surveillance@wikimedica.de

# -----------------------------------------------------------------------------
# GitHub Integration (for PubMed alerts and automation scripts)
# -----------------------------------------------------------------------------

# GitHub personal access token with repo scope (for creating issues)
# In GitHub Actions: use GITHUB_TOKEN (automatically provided)
GITHUB_TOKEN=REPLACE_WITH_GITHUB_PAT

# GitHub repository in owner/repo format
GITHUB_REPO=atmedical-wikimedica/DIG-wikimedica

# -----------------------------------------------------------------------------
# Backup Storage
# -----------------------------------------------------------------------------

# S3-compatible backup storage credentials
BACKUP_S3_ENDPOINT=REPLACE_WITH_S3_ENDPOINT_URL
BACKUP_S3_BUCKET=REPLACE_WITH_BACKUP_BUCKET_NAME
BACKUP_S3_ACCESS_KEY=REPLACE_WITH_S3_ACCESS_KEY
BACKUP_S3_SECRET_KEY=REPLACE_WITH_S3_SECRET_KEY

# Alternatively, SFTP backup target
BACKUP_SFTP_HOST=REPLACE_WITH_SFTP_HOST
BACKUP_SFTP_USER=REPLACE_WITH_SFTP_USER
BACKUP_SFTP_PATH=/backups/wikimedica

# Number of daily backups to retain
BACKUP_RETAIN_DAYS=7

# -----------------------------------------------------------------------------
# Monitoring (optional — future)
# -----------------------------------------------------------------------------

# Uptime monitoring webhook URL (e.g., Uptime Kuma, Healthchecks.io)
HEALTHCHECK_URL=REPLACE_WITH_HEALTHCHECK_PING_URL

# Alert email for deployment failures
ALERT_EMAIL=tech@wikimedica.de
