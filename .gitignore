# =============================================================================
# Wikimedica .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Secrets & Environment
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.secret
secrets/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments (explicit names to avoid matching infra/env/)
.venv/
venv/
.env_dir/
ENV/
env.bak/
venv.bak/
.python-version

# Distribution / packaging
pip-log.txt
pip-delete-this-directory.txt

# Testing
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
pytestdebug.log

# Type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb

# -----------------------------------------------------------------------------
# Node.js (for markdownlint, cspell, etc.)
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.pnp.*
package-lock.json
yarn.lock

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
# Local Docker override files (not committed – use docker-compose.override.yml)
docker-compose.local.yml

# -----------------------------------------------------------------------------
# Editors & IDEs
# -----------------------------------------------------------------------------
# VSCode
.vscode/
*.code-workspace

# JetBrains
.idea/
*.iml
*.iws
*.ipr

# Vim
*.swp
*.swo
*~
.netrwhist

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# Sublime Text
*.tmlanguage.cache
*.tmPreferences.cache
*.stTheme.cache
*.sublime-workspace

# -----------------------------------------------------------------------------
# Operating System
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
.directory

# -----------------------------------------------------------------------------
# Logs & Temporary Files
# -----------------------------------------------------------------------------
*.log
logs/
*.tmp
*.temp
*.bak
*.orig

# -----------------------------------------------------------------------------
# MediaWiki (local dev artefacts)
# -----------------------------------------------------------------------------
infra/mediawiki/LocalSettings.php
infra/mediawiki/extensions/
infra/mediawiki/skins/
infra/mediawiki/images/

# -----------------------------------------------------------------------------
# Data outputs (large generated files — committed selectively)
# -----------------------------------------------------------------------------
# Uncomment if you want to exclude generated PubMed JSONL from tracking:
# data/pubmed/*.jsonl

# Backup files
*.sql.gz
*.dump
backups/

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
*.pid
*.seed
*.pid.lock
.sass-cache/
connect.lock
